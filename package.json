{
  "name": "fitgrad-smart-fitness",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/web",
    "packages/api"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix packages/web run dev\" \"npm --prefix packages/api run dev\"",
    "dev:web": "npm --prefix packages/web run dev",
    "dev:api": "npm --prefix packages/api run dev",
    "build": "npm --prefix packages/web run build && npm --prefix packages/api run build",
    "lint": "npm --prefix packages/web run lint",
    "test": "npm --prefix packages/web run test",
    "test:watch": "npm --prefix packages/web run test:watch"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
